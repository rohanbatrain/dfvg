{
  "name": "dfvg-frontend",
  "private": true,
  "version": "1.0.0",
  "description": "DJI Footage Variant Generator – Desktop App",
  "repository": "https://github.com/rohanbatrain/dfvg",
  "author": "DFVG",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder --mac",
    "pyinstaller:build": "cd .. && source venv/bin/activate && pyinstaller dfvg-api.spec --clean",
    "dist": "npm run pyinstaller:build && npm run electron:build",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-qr-code": "^2.0.18",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "terser": "^5.46.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.dfvg.app",
    "productName": "DFVG",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../dist/dfvg-api",
        "to": "dfvg-api",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "win": {
      "target": "nsis"
    }
  }
}